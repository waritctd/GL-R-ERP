{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-uat",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5174
    },
    {
      "name": "frontend-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "5199", "--strictPort"],
      "port": 5199
    },
    {
      "name": "frontend-mock",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "5200", "--strictPort"],
      "port": 5200,
      "env": { "VITE_USE_MOCKS": "true" }
    },
    {
      "name": "frontend-mock-sales",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "5201", "--strictPort"],
      "port": 5201,
      "env": { "VITE_USE_MOCKS": "true", "VITE_ENABLE_SALES": "true" }
    }
  ]
}
