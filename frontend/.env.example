VITE_USE_MOCKS=true
VITE_API_BASE_URL=http://localhost:8080
# Shows one-click quick-login buttons on the login page for the demo accounts seeded
# by backend/src/main/resources/db/migration/V21__demo_seed_accounts.sql (real
