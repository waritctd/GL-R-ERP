VITE_USE_MOCKS=false
VITE_API_BASE_URL=http://localhost:8080
VITE_DEMO_LOGIN=false
# UAT persona quick-login on the login screen. Only meaningful against a backend seeded with
# db/migration-uat (the uat profile); keep false everywhere else — it ships a shared password.
VITE_UAT_QUICK_LOGIN=false
# Sales/CRM nav + routes. Enabled by default; set false only to hide the stack.
VITE_ENABLE_SALES=true
